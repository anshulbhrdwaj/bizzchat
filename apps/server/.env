DATABASE_URL=postgresql://postgres:password@localhost:5444/nexchat
REDIS_URL=redis://localhost:6379
JWT_SECRET=nexchat-super-secret-jwt-key-min-32-chars-dev
JWT_REFRESH_SECRET=nexchat-refresh-secret-key-min-32-chars-dev
PORT=3001
NODE_ENV=development

# Static OTP for development (use 123456 for any phone)
STATIC_OTP=true
STATIC_OTP_CODE=123456

# Media storage (local = save to disk, s3 = use AWS)
MEDIA_STORAGE=local
UPLOADS_DIR=uploads

# Twilio (not needed when STATIC_OTP=true)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# AWS S3 (not needed when MEDIA_STORAGE=local)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=nexchat-media
AWS_REGION=us-east-1

# FCM (optional for push notifications)
FCM_SERVER_KEY=

CLIENT_ORIGIN=http://localhost:5173
